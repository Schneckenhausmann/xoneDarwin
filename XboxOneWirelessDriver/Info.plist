<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>com.yourcompany.XboxOneWirelessDriver</string>

    <key>CFBundleVersion</key>
    <string>1</string>

    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>

    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <key>CFBundleName</key>
    <string>XboxOneWirelessDriver</string>

    <key>CFBundlePackageType</key>
    <string>DEXT</string>

    <key>CFBundleExecutable</key>
    <string>XboxOneWirelessDriver</string>

    <!-- DriverKit personality — IOKit matching -->
    <key>IOKitPersonalities</key>
    <dict>

        <!-- ═══ Xbox One Wireless Adapter v1 (PID 0x02E6) ═══ -->
        <key>XboxWirelessDongle_v1</key>
        <dict>
            <key>CFBundleIdentifier</key>
            <string>com.yourcompany.XboxOneWirelessDriver</string>

            <key>IOClass</key>
            <string>IOUserService</string>

            <key>IOUserClass</key>
            <string>XboxOneWirelessDriver</string>

            <!-- USB matching -->
            <key>IOProviderClass</key>
            <string>IOUSBHostDevice</string>

            <key>idVendor</key>
            <integer>1118</integer>   <!-- 0x045E Microsoft -->

            <key>idProduct</key>
            <integer>742</integer>    <!-- 0x02E6 original dongle -->

            <!-- DriverKit transport entitlement key -->
            <key>IOUserServerName</key>
            <string>com.yourcompany.XboxOneWirelessDriver</string>

            <!-- Probe score (higher = preferred over fallback drivers) -->
            <key>IOProbeScore</key>
            <integer>99500</integer>
        </dict>

        <!-- ═══ Xbox One Wireless Adapter v2 (PID 0x02FD, smaller white dongle) ═══ -->
        <key>XboxWirelessDongle_v2</key>
        <dict>
            <key>CFBundleIdentifier</key>
            <string>com.yourcompany.XboxOneWirelessDriver</string>

            <key>IOClass</key>
            <string>IOUserService</string>

            <key>IOUserClass</key>
            <string>XboxOneWirelessDriver</string>

            <key>IOProviderClass</key>
            <string>IOUSBHostDevice</string>

            <key>idVendor</key>
            <integer>1118</integer>   <!-- 0x045E Microsoft -->

            <key>idProduct</key>
            <integer>765</integer>    <!-- 0x02FD new slim dongle -->

            <key>IOUserServerName</key>
            <string>com.yourcompany.XboxOneWirelessDriver</string>

            <key>IOProbeScore</key>
            <integer>99500</integer>
        </dict>

        <!-- ═══ Virtual HID device personality ═══ -->
        <key>XboxVirtualHIDDevice</key>
        <dict>
            <key>CFBundleIdentifier</key>
            <string>com.yourcompany.XboxOneWirelessDriver</string>

            <key>IOClass</key>
            <string>IOUserService</string>

            <key>IOUserClass</key>
            <string>XboxVirtualHIDDevice</string>

            <key>IOProviderClass</key>
            <string>IOUserHIDDevice</string>

            <key>IOUserServerName</key>
            <string>com.yourcompany.XboxOneWirelessDriver</string>

            <key>IOProbeScore</key>
            <integer>99000</integer>
        </dict>

    </dict>

    <!-- OSBundleLibraries — DriverKit frameworks linked against -->
    <key>OSBundleLibraries</key>
    <dict>
        <key>com.apple.DriverKit</key>
        <string>19.0</string>

        <key>com.apple.DriverKit-USBDriverKit</key>
        <string>19.0</string>

        <key>com.apple.DriverKit-HIDDriverKit</key>
        <string>19.0</string>
    </dict>

</dict>
</plist>
